# Database
DATABASE_URL=postgresql://budgeteer:budgeteer@localhost:5432/budgeteer

# API
API_PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
# URL the browser uses to reach the app — used for CORS in Docker
APP_URL=http://localhost:3000

# Seed — initial admin account created by `npm run db:seed`
ADMIN_EMAIL=admin@budgeteer.local
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin
# Set to true to seed demo households/users on first boot
SEED_DEMO_DATA=false

# Web
VITE_API_URL=http://localhost:3001
