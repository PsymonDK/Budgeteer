# ── Required ──────────────────────────────────────────────────────────────────
# Budgeteer will refuse to start if any of these are missing.

# Auth signing key — generate with: openssl rand -hex 32
JWT_SECRET=

# Internal database password (postgres is never exposed outside Docker)
POSTGRES_PASSWORD=

# Password for the admin account created on first boot
ADMIN_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────────────

# Admin account details
ADMIN_EMAIL=admin@budgeteer.local
ADMIN_NAME=Admin

# Port the web UI is served on
APP_PORT=7272

# The URL your browser uses to reach the app.
# Change this if you access Budgeteer via a hostname, IP, or reverse proxy.
# Example: http://192.168.1.10:7272  or  https://budget.yourdomain.com
PUBLIC_URL=http://localhost:7272

# Base currency for all calculations and display (DKK, EUR, USD, GBP, ...)
BASE_CURRENCY=DKK

# Set to true to populate demo households on first boot
SEED_DEMO_DATA=false
